<%- include('partials/header') %>
  <div class="container">
    <h1 class="page-title animate-in">🏢 Company Hiring History</h1>
    <p class="page-subtitle animate-in animate-in-delay-1">Historical placement data per company from PostgreSQL</p>
    <div class="glass-card animate-in animate-in-delay-2">
      <% if (reports.length === 0) { %>
        <div class="empty-state">
          <div class="icon">🏗️</div>
          <p>No data yet. Sync from the <a href="/admin/reports" style="color:var(--primary);">Dashboard</a>.</p>
        </div>
      <% } else { %>
        <div class="table-wrapper">
          <table>
            <thead>
              <tr>
                <th>Company</th><th>Year</th><th>Jobs</th><th>Selected</th><th>Avg Pkg</th><th>Highest Pkg</th><th>Updated</th>
              </tr>
            </thead>
            <tbody>
              <% reports.forEach(function(r) { %>
                <tr>
                  <td style="font-weight:500;"><%= r.companyName %></td>
                  <td><span class="badge badge-info"><%= r.hiringYear %></span></td>
                  <td><%= r.jobsOffered %></td>
                  <td><span class="badge <%= r.studentsSelected > 0 ? 'badge-success' : 'badge-warning' %>"><%= r.studentsSelected %></span></td>
                  <td>₹<%= parseFloat(r.averagePackage).toFixed(2) %></td>
                  <td style="color:#fcd34d;font-weight:600;">₹<%= parseFloat(r.highestPackage).toFixed(2) %></td>
                  <td style="color:var(--text-secondary);font-size:0.8rem;"><%= new Date(r.createdAt).toLocaleDateString('en-IN',{day:'numeric',month:'short',year:'numeric'}) %></td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>
  </div>
</body>
</html>
