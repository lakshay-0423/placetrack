<%- include('partials/header') %>

  <div class="container">
    <h1 class="page-title animate-in">🏆 Student Leaderboard</h1>
    <p class="page-subtitle animate-in animate-in-delay-1">Students ranked by composite placement score (CGPA × Skills × Experience)</p>

    <div class="glass-card animate-in animate-in-delay-2">
      <% if (students.length === 0) { %>
        <div class="empty-state">
          <div class="icon">👤</div>
          <p>No student data available.</p>
        </div>
      <% } else { %>
        <div class="table-wrapper">
          <table>
            <thead>
              <tr>
                <th style="width: 50px;">Rank</th>
                <th>Student</th>
                <th>Branch</th>
                <th>CGPA</th>
                <th>Skills</th>
                <th>Exp (yrs)</th>
                <th>Score</th>
              </tr>
            </thead>
            <tbody>
              <% students.forEach(function(s, i) { %>
                <tr>
                  <td>
                    <span class="rank <%= i === 0 ? 'rank-1' : i === 1 ? 'rank-2' : i === 2 ? 'rank-3' : 'rank-default' %>">
                      <%= i + 1 %>
                    </span>
                  </td>
                  <td>
                    <div style="font-weight: 500;"><%= s.name %></div>
                    <div style="font-size: 0.75rem; color: var(--text-secondary);"><%= s.email %></div>
                  </td>
                  <td><span class="badge badge-primary"><%= s.branch %></span></td>
                  <td style="font-weight: 600;"><%= s.cgpa.toFixed(1) %></td>
                  <td>
                    <% if (s.skills.length > 0) { %>
                      <% s.skills.slice(0, 3).forEach(function(sk) { %>
                        <span class="badge badge-info" style="margin: 0.1rem;"><%= sk %></span>
                      <% }); %>
                      <% if (s.skills.length > 3) { %>
                        <span class="badge badge-warning">+<%= s.skills.length - 3 %></span>
                      <% } %>
                    <% } else { %>
                      <span style="color: var(--text-secondary);">—</span>
                    <% } %>
                  </td>
                  <td><%= s.experience %></td>
                  <td>
                    <div class="score-bar-container">
                      <span class="score-value"><%= s.score %></span>
                      <div class="score-bar">
                        <div class="score-bar-fill" style="width: <%= s.score %>%;"></div>
                      </div>
                    </div>
                  </td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>
  </div>
</body>
</html>
