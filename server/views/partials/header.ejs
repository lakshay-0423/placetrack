<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= typeof title !== 'undefined' ? title + ' | ' : '' %>Placement Analytics</title>
  <meta name="description" content="Campus Placement System — Admin Analytics & Reports" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg-primary: #0a0e1a;
      --bg-secondary: #111827;
      --bg-card: rgba(17, 24, 39, 0.7);
      --border-color: rgba(99, 102, 241, 0.15);
      --text-primary: #f1f5f9;
      --text-secondary: #94a3b8;
      --primary: #6366f1;
      --primary-glow: rgba(99, 102, 241, 0.35);
      --success: #10b981;
      --warning: #f59e0b;
      --error: #ef4444;
      --info: #3b82f6;
      --glass-bg: rgba(15, 23, 42, 0.6);
      --glass-border: rgba(99, 102, 241, 0.12);
      --radius: 16px;
      --shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
    }

    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
      background: var(--bg-primary);
      color: var(--text-primary);
      min-height: 100vh;
      line-height: 1.6;
    }

    /* Animated gradient background */
    body::before {
      content: '';
      position: fixed;
      top: 0; left: 0; right: 0; bottom: 0;
      background:
        radial-gradient(ellipse at 20% 20%, rgba(99, 102, 241, 0.08) 0%, transparent 50%),
        radial-gradient(ellipse at 80% 80%, rgba(16, 185, 129, 0.06) 0%, transparent 50%),
        radial-gradient(ellipse at 50% 50%, rgba(245, 158, 11, 0.04) 0%, transparent 50%);
      z-index: -1;
      animation: bgShift 20s ease-in-out infinite alternate;
    }

    @keyframes bgShift {
      0%   { opacity: 0.7; }
      100% { opacity: 1; }
    }

    /* ── Nav ── */
    .nav {
      backdrop-filter: blur(20px) saturate(180%);
      -webkit-backdrop-filter: blur(20px) saturate(180%);
      background: var(--glass-bg);
      border-bottom: 1px solid var(--glass-border);
      padding: 0.9rem 2rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      position: sticky;
      top: 0;
      z-index: 100;
    }

    .nav-brand {
      font-weight: 700;
      font-size: 1.15rem;
      background: linear-gradient(135deg, var(--primary), var(--success));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      letter-spacing: -0.3px;
    }

    .nav-links {
      display: flex;
      gap: 0.35rem;
      list-style: none;
      flex-wrap: wrap;
    }

    .nav-links a {
      color: var(--text-secondary);
      text-decoration: none;
      padding: 0.45rem 0.9rem;
      border-radius: 8px;
      font-size: 0.82rem;
      font-weight: 500;
      transition: all 0.25s ease;
      white-space: nowrap;
    }

    .nav-links a:hover,
    .nav-links a.active {
      color: var(--text-primary);
      background: rgba(99, 102, 241, 0.12);
    }

    .nav-links a.active {
      background: rgba(99, 102, 241, 0.2);
      color: #a5b4fc;
    }

    /* ── Layout ── */
    .container {
      max-width: 1280px;
      margin: 0 auto;
      padding: 2rem 1.5rem 4rem;
    }

    .page-title {
      font-size: 1.85rem;
      font-weight: 700;
      margin-bottom: 0.4rem;
      letter-spacing: -0.5px;
    }

    .page-subtitle {
      color: var(--text-secondary);
      font-size: 0.92rem;
      margin-bottom: 2rem;
    }

    /* ── Cards ── */
    .glass-card {
      backdrop-filter: blur(16px) saturate(180%);
      -webkit-backdrop-filter: blur(16px) saturate(180%);
      background: var(--bg-card);
      border: 1px solid var(--glass-border);
      border-radius: var(--radius);
      padding: 1.5rem;
      box-shadow: var(--shadow);
      transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

    .glass-card:hover {
      transform: translateY(-2px);
      box-shadow: 0 12px 40px rgba(0, 0, 0, 0.5);
    }

    /* ── Stat Grid ── */
    .stats-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 1.25rem;
      margin-bottom: 2.5rem;
    }

    .stat-card {
      text-align: center;
      padding: 1.75rem 1.25rem;
    }

    .stat-icon {
      width: 48px;
      height: 48px;
      border-radius: 12px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 1rem;
      font-size: 1.4rem;
    }

    .stat-value {
      font-size: 2rem;
      font-weight: 700;
      letter-spacing: -1px;
      line-height: 1.1;
      margin-bottom: 0.3rem;
    }

    .stat-label {
      color: var(--text-secondary);
      font-size: 0.8rem;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    /* ── Tables ── */
    .table-wrapper {
      overflow-x: auto;
      border-radius: var(--radius);
    }

    table {
      width: 100%;
      border-collapse: collapse;
      text-align: left;
      font-size: 0.88rem;
    }

    thead th {
      padding: 0.9rem 1rem;
      color: var(--text-secondary);
      font-weight: 600;
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.6px;
      border-bottom: 1px solid var(--border-color);
      position: sticky;
      top: 0;
      background: var(--bg-card);
    }

    tbody td {
      padding: 0.85rem 1rem;
      border-bottom: 1px solid rgba(255, 255, 255, 0.03);
      vertical-align: middle;
    }

    tbody tr {
      transition: background 0.2s ease;
    }

    tbody tr:hover {
      background: rgba(99, 102, 241, 0.04);
    }

    /* ── Badges ── */
    .badge {
      display: inline-block;
      padding: 0.25rem 0.65rem;
      border-radius: 20px;
      font-size: 0.72rem;
      font-weight: 600;
      letter-spacing: 0.3px;
    }

    .badge-primary { background: rgba(99, 102, 241, 0.15); color: #a5b4fc; }
    .badge-success { background: rgba(16, 185, 129, 0.15); color: #6ee7b7; }
    .badge-warning { background: rgba(245, 158, 11, 0.15); color: #fcd34d; }
    .badge-info    { background: rgba(59, 130, 246, 0.15); color: #93c5fd; }

    /* ── Rank ── */
    .rank {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 30px;
      height: 30px;
      border-radius: 8px;
      font-weight: 700;
      font-size: 0.8rem;
    }

    .rank-1 { background: linear-gradient(135deg, #fbbf24, #f59e0b); color: #1a1a2e; }
    .rank-2 { background: linear-gradient(135deg, #9ca3af, #6b7280); color: #1a1a2e; }
    .rank-3 { background: linear-gradient(135deg, #d97706, #b45309); color: #1a1a2e; }
    .rank-default { background: rgba(99, 102, 241, 0.1); color: var(--text-secondary); }

    /* ── Score bar ── */
    .score-bar-container {
      display: flex;
      align-items: center;
      gap: 0.6rem;
    }

    .score-bar {
      flex: 1;
      height: 6px;
      background: rgba(255, 255, 255, 0.06);
      border-radius: 3px;
      overflow: hidden;
      max-width: 120px;
    }

    .score-bar-fill {
      height: 100%;
      border-radius: 3px;
      background: linear-gradient(90deg, var(--primary), var(--success));
      transition: width 0.6s ease;
    }

    .score-value {
      font-weight: 600;
      font-size: 0.85rem;
      min-width: 30px;
    }

    /* ── Sync Button ── */
    .btn-sync {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.65rem 1.3rem;
      border: none;
      border-radius: 10px;
      background: linear-gradient(135deg, var(--primary), #8b5cf6);
      color: #fff;
      font-weight: 600;
      font-size: 0.85rem;
      cursor: pointer;
      transition: all 0.3s ease;
      box-shadow: 0 4px 15px var(--primary-glow);
    }

    .btn-sync:hover {
      transform: translateY(-1px);
      box-shadow: 0 6px 25px var(--primary-glow);
    }

    .btn-sync:disabled {
      opacity: 0.6;
      cursor: not-allowed;
      transform: none;
    }

    .btn-back {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      padding: 0.5rem 1rem;
      border: 1px solid var(--glass-border);
      border-radius: 8px;
      background: transparent;
      color: var(--text-secondary);
      font-size: 0.82rem;
      cursor: pointer;
      text-decoration: none;
      transition: all 0.25s ease;
    }

    .btn-back:hover {
      color: var(--text-primary);
      border-color: var(--primary);
      background: rgba(99, 102, 241, 0.08);
    }

    /* ── Empty state ── */
    .empty-state {
      text-align: center;
      padding: 3rem 1rem;
      color: var(--text-secondary);
    }

    .empty-state .icon {
      font-size: 2.5rem;
      margin-bottom: 1rem;
      opacity: 0.5;
    }

    /* ── Animations ── */
    @keyframes fadeInUp {
      from { opacity: 0; transform: translateY(16px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    .animate-in {
      animation: fadeInUp 0.5s ease forwards;
    }

    .animate-in-delay-1 { animation-delay: 0.08s; opacity: 0; }
    .animate-in-delay-2 { animation-delay: 0.16s; opacity: 0; }
    .animate-in-delay-3 { animation-delay: 0.24s; opacity: 0; }
    .animate-in-delay-4 { animation-delay: 0.32s; opacity: 0; }
    .animate-in-delay-5 { animation-delay: 0.40s; opacity: 0; }

    /* ── Responsive ── */
    @media (max-width: 768px) {
      .nav { padding: 0.75rem 1rem; flex-direction: column; gap: 0.5rem; }
      .nav-links { justify-content: center; }
      .container { padding: 1.25rem 1rem 3rem; }
      .page-title { font-size: 1.4rem; }
      .stats-grid { grid-template-columns: repeat(2, 1fr); }
      .stat-value { font-size: 1.5rem; }
    }

    @media (max-width: 480px) {
      .stats-grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>
  <nav class="nav">
    <div class="nav-brand">📊 Placement Analytics</div>
    <ul class="nav-links">
      <li><a href="/admin/reports" class="<%= typeof title !== 'undefined' && title === 'Analytics Dashboard' ? 'active' : '' %>">Dashboard</a></li>
      <li><a href="/admin/leaderboard" class="<%= typeof title !== 'undefined' && title === 'Student Leaderboard' ? 'active' : '' %>">Leaderboard</a></li>
      <li><a href="/admin/company-history" class="<%= typeof title !== 'undefined' && title === 'Company Hiring History' ? 'active' : '' %>">Company History</a></li>
      <li><a href="/admin/company-analytics" class="<%= typeof title !== 'undefined' && title === 'Company Analytics' ? 'active' : '' %>">Company Analytics</a></li>
    </ul>
  </nav>
